# Model - Number of looks

## choose the family
mean(dat$nb_look)
var(dat$nb_look)

hist(dat$nb_look)

#variance>mean => overdispersed. 
#Just two 0 in my data = represent 17% of my data so a negative binomial model (for count with over-dispersion) should be enough.

#fit and inspect the model

#No priors
m3a<-brm(nb_look ~ cdt + Prop_react + (1|Order) + (1|ID) + (1|Spot), 
        data = dat, 
        family = negbinomial())
summary(m3a) #Very high Rhat

## Diagonostic
#Check if the model converged well
plot(m3a) #did not converge well

#Model fit?
plot(conditional_effects(m3a),points=T)
pp_check(m3a) #not a good fit

#Priors
get_prior(nb_look ~ cdt + Prop_react + (1|Order) + (1|ID) + (1|Spot),
          data = dat,
          family = negbinomial()) #Flat priors

priors <- c(
  set_prior("normal(1, 1)", class = "Intercept"),
  set_prior("normal(0, 1)", class = "b"),
  set_prior("student_t(3, 0, 2.5)", class = "sd"),
  set_prior("gamma(2, 0.1)", class = "shape")
)

m3 <- brm(
  nb_look ~ cdt + Prop_react_z + (1|Order) + (1|ID) + (1|Spot), 
  data = dat,
  family = negbinomial(),
  prior = priors,
  chains = 4,
  cores = 4,
  iter = 4000,
  warmup = 1000,
  control = list(adapt_delta = 0.99, max_treedepth = 15)
)

summary(m3) #Good Rhat 

plot(m3)
conditional_effects(m3)
plot(conditional_effects(m3),points=T)
pp_check(m3)
post_m3<- posterior_samples(m3)
sum(post_m3$b_cdtTwo<0)/nrow(post_m3)




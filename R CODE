setwd("~/Documents/M2/Expe/Scripts_pour_R/Exp")
dat <- read.table("Stat.txt", header = TRUE)
head(dat)
str(dat)
dat$cdt <- factor(dat$cdt,levels=c("One","Two"))  
dat$cdt.num <- as.numeric(dat$cdt)
dat$ID <- as.factor(dat$ID)
dat$Order <- as.factor(dat$Order)
dat$Order_ID <- as.factor(dat$Order_ID)
dat$force <- as.numeric(dat$force)
dat$Prop_react_z <- scale(dat$Prop_react)

# reorder
dat <- dat[order(dat$ID,partial=dat$cdt),]

# Add a new column to the dataset, "Response". 
# This is a binary (1/0) indicator of whether an individual produced the behavioural response. 
#So any rows where Duration = 0, or Latency = Maximum, will be labelled with a 0. This tells the model that these rows are to be 'censored'.

library(dplyr)

dat <- dat %>%
  mutate(Response = ifelse(duration_look_speak == 0 | latency_first_look == max(latency_first_look), 0, 1))

# Model - Duration look

m1 <- brm(duration_look_speak | cens(1 - Response) ~ 1 + cdt + Prop_react_z + (1|Order) + (1|ID) + (1|Spot),
                      data = dat,
                      family = brmsfamily("cox"),
                      prior= prior(normal(0,1)),  
                      chains = 2, iter = 10000,
                      save_pars = save_pars(all = TRUE))


summary(m1) 
hazard(m1, b_cdtTwo)
plot(m1)
post_m1<- posterior_samples(m1)
sum(post_m1$b_cdtTwo<0)/nrow(post_m1) ## PP<0 (probability that the effect is negative: confidence in the model’s results)

# Mean = The relative difference between levels of the predictor in the rate of extinction of the outcome measure.
# e.g. if the outcome is Duration Of Looking, a ratio of 1.5 means that one condition took 1.5x as long to stop looking relative to the other condition.
# for latency, the thing being measured is the time until the START of a behaviour, so here it would be 1.5x as long until they begin looking.

# upper and lower bounds indicate robustness of the effect. If the bounds include 1.0 this would suggest a non-robust (i.e. non-sig) effect.

# Fit the Kaplan-Meier estimator
km_fit_grouped <- survfit(Surv(duration_look_speak, Response) ~ cdt, data = dat)

ggsurvplot(km_fit_grouped, 
           data = dat, 
           risk.table = TRUE, 
           conf.int = TRUE,
           ggtheme = theme_minimal(), 
           legend.title = "Condition")


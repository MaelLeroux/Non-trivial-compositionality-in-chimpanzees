# Custom function for calculating hazard ratio from a survival model

library(rstan)
library(brms)
library(parmsurvfit)
library(survival)
library(survminer)
library(dplyr)
library(tidyverse)
library(cmdstanr)
library(rstanarm)
library(tidybayes)
library(splines2)

hazard <- function(model, x){ 
  model %>% 
    tidy_draws() %>%
    mutate(`hazard ratio` = exp({{x}})) %>% 
    summarise(median = median(`hazard ratio`), sd = sd(`hazard ratio`),
              lower     = quantile(`hazard ratio`, probs = .055),
              upper     = quantile(`hazard ratio`, probs = .945)) %>% 
    mutate_all(round, digits = 4)} 

